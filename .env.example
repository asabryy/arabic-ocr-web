# Cloud SQL
CLOUDSQL_INSTANCE_CONNECTION_NAME=<project>:<region>:<instance>
MYSQL_USER=<db_username>
MYSQL_PASSWORD=<db_password>
MYSQL_DATABASE=<db_name>

# FastAPI
SECRET_KEY=<your_jwt_secret>
SENDGRID_API_KEY=<your_sendgrid_api_key>
FRONTEND_BASE_URL=<http://localhost:3000 or your live URL>

# Rate limits
REGISTER_RATE_LIMIT=5/minute
LOGIN_RATE_LIMIT=5/minute

# Doc Manager
UPLOAD_DIR=./doc-manager/uploads
STORAGE_BACKEND=local
OCR_SERVICE_URL=http://localhost:8002/ocr

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_QUEUE=ocr_tasks
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_URI=

# Cloudflare R2 (optional)
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
